# Application uploads & storage (CRITICAL: blocks private documents)
backend/uploads/*
!backend/uploads/.gitkeep

# Environment variables & secrets
.env
.env.local
.env.development
.env.production
.env.staging
.env*.local

# OS exclusions
.DS_Store
Thumbs.db
